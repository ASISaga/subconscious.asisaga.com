{
  "@context": "https://asisaga.com/ontology/v1/context.jsonld",
  "@type": "AgentActionPlan",
  "name": "Peter Drucker",
  "role": "CHRO",
  "anchor": "Knowledge_Worker_Excellence",
  "status": "Culture_Foundation",
  "overarchingPurpose": {
    "@id": "https://asisaga.com/purpose/genesis-business-infinity-mvp",
    "description": "Genesis of the Business Infinity MVP"
  },
  "actionSteps": [
    {
      "@type": "Task",
      "stepId": "CHRO_001",
      "taskName": "Articulate_Cultural_Constitution",
      "logic": "Define the three beliefs every agent and contributor must share: what the boardroom is for, what it refuses to become, and what success looks like for the mission. Culture eats strategy for breakfast — the constitution must come before the plan."
    },
    {
      "@type": "Task",
      "stepId": "CHRO_002",
      "taskName": "Design_MBO_Framework",
      "logic": "Establish Management by Objectives for the MVP: each agent role must have one measurable objective that contributes directly to the Genesis milestone. Misaligned effort is the most expensive waste — what is not aligned must be abandoned."
    },
    {
      "@type": "Task",
      "stepId": "CHRO_003",
      "taskName": "Map_Agent_Contribution_to_Strengths",
      "logic": "Ensure each boardroom agent is deployed against their legend's peak competence — the knowledge worker contributes most when placed where their strength makes the greatest difference. Ask 'what can this agent do?' before asking 'what must be done?'"
    },
    {
      "@type": "Task",
      "stepId": "CHRO_004",
      "taskName": "Create_Stakeholder_Onboarding_Guide",
      "logic": "Design the knowledge-worker onboarding experience for Business Infinity customers — the first 90 days must build confidence and clarity, not create helplessness. Management is doing things right; the onboarding must teach the right things."
    }
  ]
}
