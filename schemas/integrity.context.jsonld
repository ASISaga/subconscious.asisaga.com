{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://schema.org/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "agent": "https://asisaga.com/agents/",
    "asisaga": "https://asisaga.com/vocab/integrity#",

    "IntegrityPlan": {
      "@id": "https://asisaga.com/vocab/integrity#IntegrityPlan"
    },

    "role": {
      "@id": "schema:jobTitle",
      "@type": "xsd:string"
    },
    "legend": {
      "@id": "https://asisaga.com/vocab/integrity#legend",
      "@type": "xsd:string"
    },
    "purpose": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "tasks": {
      "@id": "schema:potentialAction",
      "@container": "@list"
    },
    "taskId": {
      "@id": "schema:identifier",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "actionStatus": {
      "@id": "schema:actionStatus"
    },
    "result": {
      "@id": "schema:result",
      "@type": "xsd:string"
    },
    "planner_task_id": {
      "@id": "https://asisaga.com/vocab/integrity#plannerTaskId",
      "@type": "xsd:string"
    }
  }
}
